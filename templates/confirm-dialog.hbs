<div class="sqt-window sqt-dialog" data-sqt-theme="{{themeId}}">
  <div class="sqt-dialog-body">
    <p class="sqt-dialog-message">{{content}}</p>
  </div>
  <footer class="sqt-sheet-footer sqt-dialog-footer">
    <button type="button" data-action="confirm" class="sqt-btn sqt-primary">
      <i class="fas fa-check"></i> Yes
    </button>
    <button type="button" data-action="cancel" class="sqt-btn">
      <i class="fas fa-times"></i> No
    </button>
  </footer>
</div>
