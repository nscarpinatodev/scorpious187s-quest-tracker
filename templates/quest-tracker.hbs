<div class="sqt-window sqt-tracker" data-sqt-theme="{{themeId}}">

  {{!-- ── Combined tab bar + action buttons (title is already in the ApplicationV2 window frame) ── --}}
  <div class="sqt-tabbar">
    <nav class="sqt-tabs" role="tablist">
      {{#each tabs}}
        <button type="button"
                class="sqt-tab-btn {{#if (sqt-eq ../activeTab id)}}active{{/if}}"
                data-tab="{{id}}"
                role="tab"
                aria-selected="{{sqt-eq ../activeTab id}}">
          <i class="{{icon}}"></i>
          <span class="sqt-tab-label">{{localize (concat "QUESTTRACKER.Tabs." id)}}</span>
          {{#with (lookup ../questsByStatus id)}}
            {{#if length}}
              <span class="sqt-badge">{{length}}</span>
            {{/if}}
          {{/with}}
        </button>
      {{/each}}
    </nav>

    <div class="sqt-tabbar-actions">
      {{#if isGM}}
        <button type="button" data-action="createQuest" class="sqt-icon-btn sqt-primary"
                title="{{localize 'QUESTTRACKER.CreateQuest'}}">
          <i class="fas fa-plus"></i>
        </button>
      {{/if}}
      {{#if isGM}}
        <button type="button" data-action="openSettings" class="sqt-icon-btn"
                title="{{localize 'QUESTTRACKER.OpenSettings'}}">
          <i class="fas fa-cog"></i>
        </button>
      {{/if}}
    </div>
  </div>

  {{!-- ── Quest Panels ── --}}
  <div class="sqt-panels">

    {{#each tabs}}
      {{#with (lookup ../questsByStatus id)}}
        <section class="sqt-tab-content {{#if (sqt-eq ../../activeTab ../id)}}active{{/if}}"
                 data-tab="{{../id}}"
                 role="tabpanel">
          {{#if length}}
            <ul class="sqt-quest-list">
              {{#each this}}
                <li class="sqt-quest-item sqt-status-{{status}}" data-quest-id="{{id}}"
                    data-action="openQuest" title="{{localize 'QUESTTRACKER.Edit'}}">

                  {{!-- Thumbnail --}}
                  <div class="sqt-quest-thumb">
                    <img src="{{thumbnail}}" alt="" draggable="false">
                    <span class="sqt-status-dot" title="{{sqt-localize-status status}}">
                      <i class="{{statusIcon}}"></i>
                    </span>
                  </div>

                  {{!-- Info --}}
                  <div class="sqt-quest-info">
                    <h3 class="sqt-quest-name">{{name}}</h3>
                    {{#if questgiver}}
                      <p class="sqt-quest-meta">
                        <i class="fas fa-user"></i> {{questgiver.name}}
                      </p>
                    {{/if}}
                    {{#if location}}
                      <p class="sqt-quest-meta">
                        <i class="fas fa-map-marker-alt"></i> {{location.name}}
                      </p>
                    {{/if}}
                  </div>

                </li>
              {{/each}}
            </ul>
          {{else}}
            <div class="sqt-empty-state">
              <i class="fas fa-scroll sqt-empty-icon"></i>
              <p>{{localize (concat "QUESTTRACKER.NoQuests." ../id)}}</p>
            </div>
          {{/if}}
        </section>
      {{/with}}
    {{/each}}

  </div>
</div>
