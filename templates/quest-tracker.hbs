<div class="sqt-window sqt-tracker" data-sqt-theme="{{themeId}}">

  {{!-- ── Header ── --}}
  <header class="sqt-header">
    <div class="sqt-header-brand">
      <i class="fas fa-scroll sqt-header-icon"></i>
      <h1 class="sqt-header-title">{{localize "QUESTTRACKER.Title"}}</h1>
    </div>
    <div class="sqt-header-controls">
      {{#if isGM}}
        <button type="button" data-action="createQuest" class="sqt-icon-btn sqt-primary"
                title="{{localize 'QUESTTRACKER.CreateQuest'}}">
          <i class="fas fa-plus"></i>
        </button>
      {{/if}}
      <button type="button" data-action="openSettings" class="sqt-icon-btn"
              title="{{localize 'QUESTTRACKER.OpenSettings'}}">
        <i class="fas fa-cog"></i>
      </button>
    </div>
  </header>

  {{!-- ── Tab Bar ── --}}
  <nav class="sqt-tabs" role="tablist">
    {{#each tabs}}
      <button type="button"
              class="sqt-tab-btn {{#if (sqt-eq ../activeTab id)}}active{{/if}}"
              data-tab="{{id}}"
              role="tab"
              aria-selected="{{sqt-eq ../activeTab id}}">
        <i class="{{icon}}"></i>
        <span class="sqt-tab-label">{{localize (concat "QUESTTRACKER.Tabs." id)}}</span>
        {{#with (lookup ../questsByStatus id)}}
          {{#if length}}
            <span class="sqt-badge">{{length}}</span>
          {{/if}}
        {{/with}}
      </button>
    {{/each}}
  </nav>

  {{!-- ── Quest Panels ── --}}
  <div class="sqt-panels">

    {{#each tabs}}
      {{#with (lookup ../questsByStatus id)}}
        <section class="sqt-tab-content {{#if (sqt-eq ../../activeTab ../id)}}active{{/if}}"
                 data-tab="{{../id}}"
                 role="tabpanel">
          {{#if length}}
            <ul class="sqt-quest-list">
              {{#each this}}
                <li class="sqt-quest-item sqt-status-{{status}}" data-quest-id="{{id}}">

                  {{!-- Thumbnail --}}
                  <div class="sqt-quest-thumb">
                    <img src="{{thumbnail}}" alt="" draggable="false">
                    <span class="sqt-status-dot" title="{{sqt-localize-status status}}">
                      <i class="{{statusIcon}}"></i>
                    </span>
                  </div>

                  {{!-- Info --}}
                  <div class="sqt-quest-info">
                    <h3 class="sqt-quest-name">{{name}}</h3>
                    {{#if questgiver}}
                      <p class="sqt-quest-meta">
                        <i class="fas fa-user"></i> {{questgiver.name}}
                      </p>
                    {{/if}}
                    {{#if location}}
                      <p class="sqt-quest-meta">
                        <i class="fas fa-map-marker-alt"></i> {{location.name}}
                      </p>
                    {{/if}}
                    {{#if (sqt-gt objectives.length 0)}}
                      <p class="sqt-quest-meta sqt-objectives-summary">
                        <i class="fas fa-tasks"></i>
                        {{#each objectives}}{{#if completed}}<s>{{text}}</s>{{else}}{{text}}{{/if}}{{#unless @last}}, {{/unless}}{{/each}}
                      </p>
                    {{/if}}
                  </div>

                  {{!-- Actions --}}
                  {{#if ../../isGM}}
                    <div class="sqt-quest-actions">
                      <button type="button" data-action="openQuest" data-quest-id="{{id}}"
                              class="sqt-icon-btn sqt-sm" title="{{localize 'QUESTTRACKER.Edit'}}">
                        <i class="fas fa-edit"></i>
                      </button>

                      {{#if (sqt-eq status "inactive")}}
                        <button type="button" data-action="makeAvailable" data-quest-id="{{id}}"
                                class="sqt-icon-btn sqt-sm" title="{{localize 'QUESTTRACKER.MakeAvailable'}}">
                          <i class="fas fa-eye"></i>
                        </button>
                      {{/if}}

                      {{#if (sqt-eq status "available")}}
                        <button type="button" data-action="sendQuestNote" data-quest-id="{{id}}"
                                class="sqt-icon-btn sqt-sm" title="{{localize 'QUESTTRACKER.Send'}}">
                          <i class="fas fa-paper-plane"></i>
                        </button>
                      {{/if}}

                      {{#if (sqt-eq status "active")}}
                        <button type="button" data-action="sendQuestNote" data-quest-id="{{id}}"
                                class="sqt-icon-btn sqt-sm" title="{{localize 'QUESTTRACKER.Send'}}">
                          <i class="fas fa-paper-plane"></i>
                        </button>
                        <button type="button" data-action="completeQuest" data-quest-id="{{id}}"
                                class="sqt-icon-btn sqt-sm sqt-success" title="{{localize 'QUESTTRACKER.Complete'}}">
                          <i class="fas fa-check"></i>
                        </button>
                        <button type="button" data-action="failQuest" data-quest-id="{{id}}"
                                class="sqt-icon-btn sqt-sm sqt-danger" title="{{localize 'QUESTTRACKER.Fail'}}">
                          <i class="fas fa-times"></i>
                        </button>
                      {{/if}}

                      {{#if (sqt-or (sqt-eq status "completed") (sqt-eq status "failed"))}}
                        <button type="button" data-action="reactivate" data-quest-id="{{id}}"
                                class="sqt-icon-btn sqt-sm" title="{{localize 'QUESTTRACKER.Reactivate'}}">
                          <i class="fas fa-undo"></i>
                        </button>
                      {{/if}}

                      <button type="button" data-action="deleteQuest" data-quest-id="{{id}}"
                              class="sqt-icon-btn sqt-sm sqt-danger" title="{{localize 'QUESTTRACKER.Delete'}}">
                        <i class="fas fa-trash"></i>
                      </button>
                    </div>
                  {{else}}
                    <div class="sqt-quest-actions">
                      <button type="button" data-action="openQuest" data-quest-id="{{id}}"
                              class="sqt-icon-btn sqt-sm" title="{{localize 'QUESTTRACKER.Edit'}}">
                        <i class="fas fa-eye"></i>
                      </button>
                    </div>
                  {{/if}}

                </li>
              {{/each}}
            </ul>
          {{else}}
            <div class="sqt-empty-state">
              <i class="fas fa-scroll sqt-empty-icon"></i>
              <p>{{localize (concat "QUESTTRACKER.NoQuests." ../id)}}</p>
            </div>
          {{/if}}
        </section>
      {{/with}}
    {{/each}}

  </div>
</div>
