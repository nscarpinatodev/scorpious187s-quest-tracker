<div class="sqt-window sqt-config" data-sqt-theme="{{themeId}}">

  <div class="sqt-config-body">

    {{!-- ════ SYSTEM SECTION ════ --}}
    <section class="sqt-config-section">
      <h2 class="sqt-section-title">
        <i class="fas fa-dice-d20"></i>
        {{localize "QUESTTRACKER.Settings.System.Title"}}
      </h2>

      <div class="sqt-form-row">
        <label for="sqt-system-preset" class="sqt-form-label">
          {{localize "QUESTTRACKER.Settings.System.Preset"}}
        </label>
        <div class="sqt-form-control">
          <select id="sqt-system-preset" name="systemPreset">
            {{#each systemPresets}}
              <option value="{{id}}" {{#if (sqt-eq ../sysConfig.preset id)}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <button type="button" data-action="loadPreset" class="sqt-btn sqt-sm">
            <i class="fas fa-sync-alt"></i> Load Preset
          </button>
          <p class="sqt-hint">{{localize "QUESTTRACKER.Settings.System.PresetHint"}}</p>
        </div>
      </div>

      <div class="sqt-toggle-grid">
        <label for="sqt-xp-enabled" class="sqt-checkbox-label">
          {{localize "QUESTTRACKER.Settings.System.XPEnabled"}}
          <span class="sqt-hint">{{localize "QUESTTRACKER.Settings.System.XPEnabledHint"}}</span>
        </label>
        <input type="checkbox" id="sqt-xp-enabled" class="sqt-checkbox"
               {{#if sysConfig.xpEnabled}}checked{{/if}}>

        <label for="sqt-currency-enabled" class="sqt-checkbox-label">
          {{localize "QUESTTRACKER.Settings.System.CurrencyEnabled"}}
          <span class="sqt-hint">{{localize "QUESTTRACKER.Settings.System.CurrencyEnabledHint"}}</span>
        </label>
        <input type="checkbox" id="sqt-currency-enabled" class="sqt-checkbox"
               {{#if sysConfig.currencyEnabled}}checked{{/if}}>
      </div>

      {{!-- Currency Types --}}
      <div class="sqt-form-group">
        <label class="sqt-form-label">
          {{localize "QUESTTRACKER.Settings.System.CurrencyTypes"}}
        </label>
        <div class="sqt-currency-header sqt-form-row-inner">
          <span>{{localize "QUESTTRACKER.Settings.System.CurrencyKey"}}</span>
          <span>{{localize "QUESTTRACKER.Settings.System.CurrencyLabel"}}</span>
          <span>{{localize "QUESTTRACKER.Settings.System.CurrencyConversion"}}</span>
          <span></span>
        </div>
        <div id="sqt-currency-list" class="sqt-currency-list">
          {{#each currency}}
            <div class="sqt-currency-row">
              <input type="text" class="sqt-cur-key"   value="{{key}}"        placeholder="gp"   maxlength="8">
              <input type="text" class="sqt-cur-label" value="{{label}}"      placeholder="Gold">
              <input type="number" class="sqt-cur-conv" value="{{conversion}}" placeholder="1.0" step="0.01" min="0">
              <button type="button" data-action="removeCurrency" class="sqt-icon-btn sqt-sm sqt-danger" title="Remove">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          {{/each}}
        </div>
        <button type="button" data-action="addCurrency" class="sqt-btn sqt-sm">
          <i class="fas fa-plus"></i> {{localize "QUESTTRACKER.Settings.System.AddCurrency"}}
        </button>
      </div>

      <div class="sqt-form-row">
        <label for="sqt-min-objective-role" class="sqt-form-label">
          {{localize "QUESTTRACKER.Settings.System.MinObjectiveRole"}}
          <span class="sqt-hint">{{localize "QUESTTRACKER.Settings.System.MinObjectiveRoleHint"}}</span>
        </label>
        <div class="sqt-form-control">
          <select id="sqt-min-objective-role" name="minObjectiveRole">
            {{#each roleOptions}}
              <option value="{{value}}" {{#if (sqt-eq ../minObjectiveRole value)}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
      </div>

      <div class="sqt-form-row">
        <label for="sqt-drag-permission" class="sqt-form-label">
          {{localize "QUESTTRACKER.Settings.System.DragPermission"}}
          <span class="sqt-hint">{{localize "QUESTTRACKER.Settings.System.DragPermissionHint"}}</span>
        </label>
        <div class="sqt-form-control">
          <select id="sqt-drag-permission" name="dragPermission">
            {{#each dragPermissionOptions}}
              <option value="{{value}}" {{#if (sqt-eq ../dragPermission value)}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </section>

    {{!-- ════ THEME SECTION ════ --}}
    <section class="sqt-config-section">
      <h2 class="sqt-section-title">
        <i class="fas fa-palette"></i>
        {{localize "QUESTTRACKER.Settings.Theme.Title"}}
      </h2>

      <div class="sqt-form-row">
        <label for="sqt-theme-select" class="sqt-form-label">
          {{localize "QUESTTRACKER.Settings.Theme.SelectTheme"}}
        </label>
        <div class="sqt-form-control">
          <select id="sqt-theme-select">
            {{#each themeCategories}}
              <optgroup label="{{label}}">
                {{#each themes}}
                  <option value="{{id}}" {{#if (sqt-eq ../../themeId id)}}selected{{/if}}>
                    {{label}} — {{description}}
                  </option>
                {{/each}}
              </optgroup>
            {{/each}}
          </select>
          <button type="button" data-action="previewTheme" class="sqt-btn sqt-sm">
            <i class="fas fa-eye"></i> Preview
          </button>
        </div>
      </div>

      <div class="sqt-form-row">
        <label for="sqt-font-heading" class="sqt-form-label">Heading Font</label>
        <div class="sqt-form-control">
          <select id="sqt-font-heading">
            <optgroup label="System Fonts">
              {{#each fontOptions}}
                <option value="{{value}}" {{#if (sqt-eq ../fontHeading value)}}selected{{/if}}
                        style="font-family: {{value}}">{{label}}</option>
              {{/each}}
            </optgroup>
            {{#if foundryFontOptions.length}}
              <optgroup label="Foundry Fonts">
                {{#each foundryFontOptions}}
                  <option value="{{value}}" {{#if (sqt-eq ../fontHeading value)}}selected{{/if}}
                          style="font-family: {{value}}">{{label}}</option>
                {{/each}}
              </optgroup>
            {{/if}}
          </select>
        </div>
      </div>

      <div class="sqt-form-row">
        <label for="sqt-font-body" class="sqt-form-label">Body Font</label>
        <div class="sqt-form-control">
          <select id="sqt-font-body">
            <optgroup label="System Fonts">
              {{#each fontOptions}}
                <option value="{{value}}" {{#if (sqt-eq ../fontBody value)}}selected{{/if}}
                        style="font-family: {{value}}">{{label}}</option>
              {{/each}}
            </optgroup>
            {{#if foundryFontOptions.length}}
              <optgroup label="Foundry Fonts">
                {{#each foundryFontOptions}}
                  <option value="{{value}}" {{#if (sqt-eq ../fontBody value)}}selected{{/if}}
                          style="font-family: {{value}}">{{label}}</option>
                {{/each}}
              </optgroup>
            {{/if}}
          </select>
        </div>
      </div>

      {{!-- Custom theme overrides (shown when "custom" is selected) --}}
      <details class="sqt-custom-theme-details">
        <summary>{{localize "QUESTTRACKER.Settings.Theme.CustomColors"}}</summary>
        <div class="sqt-custom-theme-grid">
          <div class="sqt-custom-var-row">
            <label>Primary Background</label>
            <input type="color" class="sqt-custom-var" data-var="--sqt-bg-primary"
                   value="{{lookup customVars '--sqt-bg-primary'}}">
            <input type="text"  class="sqt-custom-var-hex" placeholder="#2d2d2d">
          </div>
          <div class="sqt-custom-var-row">
            <label>Secondary Background</label>
            <input type="color" class="sqt-custom-var" data-var="--sqt-bg-secondary"
                   value="{{lookup customVars '--sqt-bg-secondary'}}">
            <input type="text"  class="sqt-custom-var-hex" placeholder="#1a1a1a">
          </div>
          <div class="sqt-custom-var-row">
            <label>Primary Text</label>
            <input type="color" class="sqt-custom-var" data-var="--sqt-text-primary"
                   value="{{lookup customVars '--sqt-text-primary'}}">
            <input type="text"  class="sqt-custom-var-hex" placeholder="#e0e0e0">
          </div>
          <div class="sqt-custom-var-row">
            <label>Accent Color</label>
            <input type="color" class="sqt-custom-var" data-var="--sqt-accent"
                   value="{{lookup customVars '--sqt-accent'}}">
            <input type="text"  class="sqt-custom-var-hex" placeholder="#c9aa71">
          </div>
          <div class="sqt-custom-var-row">
            <label>Border Color</label>
            <input type="color" class="sqt-custom-var" data-var="--sqt-border"
                   value="{{lookup customVars '--sqt-border'}}">
            <input type="text"  class="sqt-custom-var-hex" placeholder="#4a4a4a">
          </div>
        </div>
      </details>
    </section>

    {{!-- ════ NOTIFICATIONS SECTION ════ --}}
    <section class="sqt-config-section">
      <h2 class="sqt-section-title">
        <i class="fas fa-bell"></i>
        {{localize "QUESTTRACKER.Settings.Notifications.Title"}}
      </h2>

      <div class="sqt-toggle-grid">
        <label for="sqt-note-enabled" class="sqt-checkbox-label">
          {{localize "QUESTTRACKER.Settings.Notifications.QuestNoteEnabled"}}
          <span class="sqt-hint">{{localize "QUESTTRACKER.Settings.Notifications.QuestNoteEnabledHint"}}</span>
        </label>
        <input type="checkbox" id="sqt-note-enabled" class="sqt-checkbox"
               {{#if notifPrefs.questNoteEnabled}}checked{{/if}}>

        <label for="sqt-auto-tracker" class="sqt-checkbox-label">
          {{localize "QUESTTRACKER.Settings.Notifications.AutoShowActive"}}
          <span class="sqt-hint">{{localize "QUESTTRACKER.Settings.Notifications.AutoShowActiveHint"}}</span>
        </label>
        <input type="checkbox" id="sqt-auto-tracker" class="sqt-checkbox"
               {{#if notifPrefs.autoShowTracker}}checked{{/if}}>
      </div>
    </section>

  </div>{{!-- /.sqt-config-body --}}

  <footer class="sqt-sheet-footer">
    <button type="button" data-action="save" class="sqt-btn sqt-primary">
      <i class="fas fa-save"></i> {{localize "QUESTTRACKER.Save"}}
    </button>
    <button type="button" data-action="cancel" class="sqt-btn">
      <i class="fas fa-times"></i> {{localize "QUESTTRACKER.Cancel"}}
    </button>
  </footer>

</div>
